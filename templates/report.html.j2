<!DOCTYPE html>
<html lang="zh-CN">
<head><meta charset="UTF-8"><title>{{ symbol }} 行情分析报告</title>
<style>
  body { font-family: monospace; background: #0d1117; color: #c9d1d9; padding: 2em; }
  h1 { color: #58a6ff; }
  .bullish { color: #3fb950; } .bearish { color: #f85149; } .neutral { color: #d29922; }
  table { border-collapse: collapse; width: 100%; }
  td, th { border: 1px solid #30363d; padding: 8px; text-align: left; }
  .dispute { color: #f85149; font-size: 0.9em; }
</style></head>
<body>
<h1>{{ symbol }} 行情分析报告 {{ timestamp }}</h1>
<h2>数据质量</h2>
<p>已验证: {{ verified_data_count }} 字段 | 未验证: {{ unverified_data_count }} 字段</p>
<h2>各维度分析</h2>
<table>
  <tr><th>Agent</th><th>信号</th><th>信心</th></tr>
  {% for agent, s in agent_signals.items() %}
  <tr><td>{{ agent }}</td>
      <td class="{{ s.signal }}">{{ s.signal }}</td>
      <td>{{ s.confidence }}%</td></tr>
  {% endfor %}
</table>
<h2>综合建议</h2>
<p class="{{ signal }}">{{ signal.upper() }} — 信心 {{ confidence }}%</p>
{% if stop_loss %}<p>止损位: ${{ stop_loss }}</p>{% endif %}
<h2>主要观点</h2>
<ul>{% for kp in key_points %}<li>{{ kp }}</li>{% endfor %}</ul>
{% if disputes %}
<h2>未解决分歧（风险项）</h2>
{% for d in disputes %}<p class="dispute">⚠ {{ d }}</p>{% endfor %}
{% endif %}
</body></html>
